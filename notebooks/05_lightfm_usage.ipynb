   "source": [
    "{\n",
    " \"cells\": [\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# LightFM Hybrid Demo\\n\",\n",
    "    \"\\n\",\n",
    "    \"This notebook demonstrates the `LightFMHybridModel` wrapper and shows a feature influence analysis.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"import pandas as pd\\n\",\n",
    "    \"\\n\",\n",
    "    \"from src.evaluation import LightFMFeatureInfluenceAnalyzer\\n\",\n",
    "    \"from src.evaluation import LightFMFeatureInfluenceConfig\\n\",\n",
    "    \"from src.models.lightfm_model import LightFMHybridModel\"\n",
    "   ],\n",
    "   \"execution_count\": null,\n",
    "   \"outputs\": []\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# Build a small ratings dataframe\\n\",\n",
    "    \"ratings_dataframe = pd.DataFrame(\\n\",\n",
    "    \"    {\\n\",\n",
    "    \"        \\\"userId\\\": [1, 1, 1, 2, 2, 3, 3, 3, 4, 4],\\n\",\n",
    "    \"        \\\"movieId\\\": [1, 2, 3, 1, 4, 2, 3, 5, 1, 5],\\n\",\n",
    "    \"        \\\"rating\\\": [4.0, 3.5, 2.0, 4.5, 3.0, 4.0, 3.0, 5.0, 2.5, 4.5],\\n\",\n",
    "    \"    }\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Build a small movies feature dataframe using engineered columns\\n\",\n",
    "    \"movies_feature_dataframe = pd.DataFrame(\\n\",\n",
    "    \"    {\\n\",\n",
    "    \"        \\\"movieId\\\": [1, 2, 3, 4, 5, 6],\\n\",\n",
    "    \"        \\\"genre_Action\\\": [1, 0, 0, 1, 0, 1],\\n\",\n",
    "    \"        \\\"genre_Comedy\\\": [0, 1, 1, 0, 1, 0],\\n\",\n",
    "    \"        \\\"genre_tfidf_action\\\": [0.9, 0.0, 0.0, 0.8, 0.0, 0.7],\\n\",\n",
    "    \"        \\\"genre_tfidf_comedy\\\": [0.0, 0.8, 0.7, 0.0, 0.9, 0.0],\\n\",\n",
    "    \"        \\\"release_year\\\": [1995, 1998, 2001, 2005, 2010, 2012],\\n\",\n",
    "    \"    }\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"ratings_dataframe.head(), movies_feature_dataframe.head()\"\n",
    "   ],\n",
    "   \"execution_count\": null,\n",
    "   \"outputs\": []\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# Fit LightFM hybrid model with item features\\n\",\n",
    "    \"model = LightFMHybridModel(number_of_components=8, number_of_epochs=8, random_seed=7)\\n\",\n",
    "    \"model.fit(ratings_dataframe=ratings_dataframe, movies_dataframe=movies_feature_dataframe)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Predict one user-item score\\n\",\n",
    "    \"predicted_score = model.predict_rating(user_identifier=1, movie_identifier=4)\\n\",\n",
    "    \"print(\\\"Predicted score for user 1 on movie 4:\\\", predicted_score)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Top-3 recommendations for user 1 (unseen items only)\\n\",\n",
    "    \"recommendations = model.recommend_top_n(user_identifier=1, number_of_recommendations=3)\\n\",\n",
    "    \"print(\\\"Top-3 recommendations for user 1:\\\")\\n\",\n",
    "    \"for movie_id, score in recommendations:\\n\",\n",
    "    \"    print(\\\" \\\", movie_id, score)\"\n",
    "   ],\n",
    "   \"execution_count\": null,\n",
    "   \"outputs\": []\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Feature Influence Analysis\\n\",\n",
    "    \"\\n\",\n",
    "    \"Positive influence means removing the feature worsens the selected metric.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# Create a tiny split for the demo analysis.\\n\",\n",
    "    \"train_dataframe = ratings_dataframe.iloc[:8].copy()\\n\",\n",
    "    \"validation_dataframe = ratings_dataframe.iloc[8:].copy()\\n\",\n",
    "    \"\\n\",\n",
    "    \"influence_analyzer = LightFMFeatureInfluenceAnalyzer(\\n\",\n",
    "    \"    LightFMFeatureInfluenceConfig(\\n\",\n",
    "    \"        metric_name=\\\"rmse_value\\\",\\n\",\n",
    "    \"        number_of_components=8,\\n\",\n",
    "    \"        number_of_epochs=6,\\n\",\n",
    "    \"        random_seed=7,\\n\",\n",
    "    \"    )\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"feature_influence_dataframe = influence_analyzer.analyze(\\n\",\n",
    "    \"    train_dataframe=train_dataframe,\\n\",\n",
    "    \"    validation_dataframe=validation_dataframe,\\n\",\n",
    "    \"    movies_dataframe=movies_feature_dataframe,\\n\",\n",
    "    \")\\n\",\n",
    "    \"feature_influence_dataframe\"\n",
    "   ],\n",
    "   \"execution_count\": null,\n",
    "   \"outputs\": []\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# Show strongest positive and negative features for accuracy.\\n\",\n",
    "    \"print(\\\"Most positive influence:\\\")\\n\",\n",
    "    \"print(feature_influence_dataframe.head(3)[[\\\"feature_name\\\", \\\"influence_score\\\", \\\"influence_direction\\\"]])\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"\\\\nMost negative influence:\\\")\\n\",\n",
    "    \"print(feature_influence_dataframe.tail(3)[[\\\"feature_name\\\", \\\"influence_score\\\", \\\"influence_direction\\\"]])\"\n",
    "   ],\n",
    "   \"execution_count\": null,\n",
    "   \"outputs\": []\n",
    "  }\n",
    " ],\n",

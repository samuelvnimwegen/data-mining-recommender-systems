   "source": [
    "{\n",
    " \"cells\": [\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"id\": \"f4a48f8a\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# Ratings Splitter Demo\\n\",\n",
    "    \"\\n\",\n",
    "    \"This notebook creates a 70/30 per-user split for only 50 sampled users and keeps all other users fully in train.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"id\": \"9f1fe719\",\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"from pathlib import Path\\n\",\n",
    "    \"\\n\",\n",
    "    \"import pandas as pd\\n\",\n",
    "    \"\\n\",\n",
    "    \"from src.dataloader.ratings_splitter import RatingsSplitter, split_ratings_train_val\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"id\": \"2fc2f284\",\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Find project root from notebook folder.\\n\",\n",
    "    \"project_root_path = Path.cwd()\\n\",\n",
    "    \"if not (project_root_path / \\\"src\\\").exists():\\n\",\n",
    "    \"    project_root_path = project_root_path.parent\\n\",\n",
    "    \"\\n\",\n",
    "    \"ratings_input_path = project_root_path / \\\"data\\\" / \\\"raw\\\" / \\\"ratings_train.csv\\\"\\n\",\n",
    "    \"output_directory_path = project_root_path / \\\"data\\\" / \\\"processed\\\" / \\\"notebook_demo\\\"\\n\",\n",
    "    \"output_directory_path.mkdir(parents=True, exist_ok=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"ratings_dataframe = pd.read_csv(ratings_input_path)\\n\",\n",
    "    \"print(f\\\"Loaded ratings rows: {len(ratings_dataframe)}\\\")\\n\",\n",
    "    \"print(f\\\"Loaded unique users: {ratings_dataframe['userId'].nunique()}\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"id\": \"bb8b4f76\",\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Build splitter with assignment settings.\\n\",\n",
    "    \"# Only 50 users are sampled for validation holdout.\\n\",\n",
    "    \"ratings_splitter = RatingsSplitter(\\n\",\n",
    "    \"    val_fraction=0.3,\\n\",\n",
    "    \"    min_interactions=2,\\n\",\n",
    "    \"    seed=42,\\n\",\n",
    "    \"    max_validation_users=50,\\n\",\n",
    "    \")\\n\",\n",
    "    \"train_dataframe, validation_dataframe = ratings_splitter.split(ratings_dataframe)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"Train rows: {len(train_dataframe)}\\\")\\n\",\n",
    "    \"print(f\\\"Validation rows: {len(validation_dataframe)}\\\")\\n\",\n",
    "    \"print(f\\\"Total rows kept: {len(train_dataframe) + len(validation_dataframe)}\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"id\": \"0c7ff177\",\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Check split safety rules.\\n\",\n",
    "    \"validation_user_ids = set(validation_dataframe[\\\"userId\\\"].astype(int).tolist())\\n\",\n",
    "    \"train_user_ids = set(train_dataframe[\\\"userId\\\"].astype(int).tolist())\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Every validation user must also be in train.\\n\",\n",
    "    \"assert validation_user_ids.issubset(train_user_ids)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Limit validation to 50 users.\\n\",\n",
    "    \"assert len(validation_user_ids) <= 50\\n\",\n",
    "    \"\\n\",\n",
    "    \"# No row can exist in both sets.\\n\",\n",
    "    \"train_pairs = set(train_dataframe[[\\\"userId\\\", \\\"movieId\\\"]].itertuples(index=False, name=None))\\n\",\n",
    "    \"validation_pairs = set(validation_dataframe[[\\\"userId\\\", \\\"movieId\\\"]].itertuples(index=False, name=None))\\n\",\n",
    "    \"assert train_pairs.isdisjoint(validation_pairs)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"Users in train: {len(train_user_ids)}\\\")\\n\",\n",
    "    \"print(f\\\"Users in validation: {len(validation_user_ids)}\\\")\\n\",\n",
    "    \"print(\\\"Validation users are subset of train users: True\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"id\": \"4d7d8332\",\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Show helper function gives same deterministic split.\\n\",\n",
    "    \"function_train_dataframe, function_validation_dataframe = split_ratings_train_val(\\n\",\n",
    "    \"    ratings_dataframe=ratings_dataframe,\\n\",\n",
    "    \"    val_fraction=0.3,\\n\",\n",
    "    \"    min_interactions=2,\\n\",\n",
    "    \"    seed=42,\\n\",\n",
    "    \"    max_validation_users=50,\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(train_dataframe.equals(function_train_dataframe))\\n\",\n",
    "    \"print(validation_dataframe.equals(function_validation_dataframe))\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"id\": \"158e4d4b\",\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Save split files for model training and validation.\\n\",\n",
    "    \"train_output_path = output_directory_path / \\\"ratings_train_split.csv\\\"\\n\",\n",
    "    \"validation_output_path = output_directory_path / \\\"ratings_validation_split.csv\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"train_dataframe.to_csv(train_output_path, index=False)\\n\",\n",
    "    \"validation_dataframe.to_csv(validation_output_path, index=False)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"Saved train split: {train_output_path}\\\")\\n\",\n",
    "    \"print(f\\\"Saved validation split: {validation_output_path}\\\")\\n\",\n",
    "    \"train_dataframe.head(3), validation_dataframe.head(3)\"\n",
    "   ]\n",
    "  }\n",
    " ],\n",
